# ===== Claude AI =====
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ===== ElevenLabs TTS =====
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ===== 치지직(Chzzk) =====
# 네이버 로그인 후 브라우저 개발자도구 > Application > Cookies > chzzk.naver.com 에서 복사
CHZZK_NID_AUT=your_naver_nid_aut_cookie
CHZZK_NID_SES=your_naver_nid_ses_cookie
CHZZK_CHANNEL_ID=your_chzzk_channel_id

# ===== VTube Studio =====
VTUBE_STUDIO_PORT=8001
VTUBE_STUDIO_PLUGIN_NAME=AI_Streamer
VTUBE_STUDIO_TOKEN_FILE=.vtube_token

# ===== 스트리머 설정 =====
STREAMER_NAME=하나
RESPONSE_COOLDOWN=8        # 채팅 응답 쿨다운 (초)
SOLILOQUY_INTERVAL=120     # 채팅 없을 때 독백 간격 (초)
MAX_HISTORY=20             # 대화 히스토리 최대 개수

# ===== 오디오 설정 =====
# sounddevice로 출력할 장치 이름 (VoiceMeeter 사용 시 "VoiceMeeter Input" 등으로 설정)
# 비워두면 기본 출력 장치 사용
AUDIO_OUTPUT_DEVICE=
